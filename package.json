{
  "name": "barbershop-scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3007": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 3007",
    "dev:3008": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 3008",
    "dev:3009": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 3009",
    "dev:3010": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 3010",
    "kill-ports": "powershell -ExecutionPolicy Bypass -File ./kill-ports.ps1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "autoprefixer": "^10.4.16",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.294.0",
    "minimatch": "^9.0.9",
    "next": "^15.5.15",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.73.1",
    "react-input-mask": "^2.0.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.3.6",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-input-mask": "^3.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
