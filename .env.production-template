# ==========================================
# BARBER SHOP SaaS - PRODUCTION TEMPLATE
# ==========================================
# Copiar para .env.production e preencher valores reais

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# OPÇÃO 1: Prisma Data Proxy (Recomendado para Vercel)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=SUA_API_KEY_AQUI

# OPÇÃO 2: PostgreSQL Direto (Neon, Supabase, etc)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ==========================================
# AUTHENTICATION CONFIGURATION
# ==========================================
# Gerar secrets: openssl rand -base64 32
JWT_SECRET=seu-super-secret-jwt-key-32-caracteres-minimo
NEXTAUTH_SECRET=seu-super-secret-nextauth-key-32-caracteres-minimo

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production
NEXTAUTH_URL=https://seu-dominio.vercel.app

# ==========================================
# INSTRUÇÕES
# ==========================================
# 1. Escolher OPÇÃO 1 ou OPÇÃO 2 para DATABASE_URL
# 2. Preencher secrets reais (32+ caracteres)
# 3. Atualizar NEXTAUTH_URL com domínio real
# 4. Copiar para Vercel Dashboard > Environment Variables
# 5. Fazer deploy: vercel --prod
