# Database Configuration - PRODUCTION
# PostgreSQL cloud connection (Neon, Supabase, Railway)
# Format: postgresql://user:password@host:5432/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# JWT Configuration - PRODUCTION
# Secret key for JWT token generation (use a strong, random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-32-chars-min"

# Application Configuration
NODE_ENV="production"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production-32-chars-min"

# Optional: External Services for Production
# EMAIL_SERVICE_PROVIDER="sendgrid"
# EMAIL_API_KEY="your-email-service-api-key"
# STRIPE_SECRET_KEY="your-stripe-secret-key"
# STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
