# ==========================================
# BARBER SHOP SaaS - VERCEL PRODUCTION FIX
# ==========================================
# Use este arquivo para corrigir o erro de Prisma Data Proxy

# ==========================================
# DATABASE CONFIGURATION - PRISMA DATA PROXY
# ==========================================
# Usar URL do Prisma Accelerate (Data Proxy)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..xLXh4cOjOILbAOl1H2hy5U6TgPzX8YRq8MhuFrljBB0

# ==========================================
# AUTHENTICATION CONFIGURATION - PRODUCTION
# ==========================================
# JWT Secret for token generation (32+ characters)
JWT_SECRET=barber-shop-super-secret-jwt-key-32-chars-minimum-for-production

# NextAuth.js configuration
NEXTAUTH_SECRET=barber-shop-super-secret-nextauth-key-32-chars-minimum-for-production
NEXTAUTH_URL=https://barbeariaapp.vercel.app

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production

# ==========================================
# INSTRUÇÕES PARA CORRIGIR O ERRO
# ==========================================
# 1. Acesse: https://vercel.com/dashboard/weslleson22s-projects/barbeariaapp/settings/environment-variables
# 2. ATUALIZE APENAS o DATABASE_URL com a URL acima (prisma+postgres://)
# 3. Mantenha as outras variáveis como estão
# 4. Deploy novamente: vercel --prod
# 5. Teste cadastro: https://barbeariaapp.vercel.app/register

# ==========================================
# EXPLICAÇÃO DO ERRO
# ==========================================
# O erro "the URL must start with the protocol 'prisma://'" acontece porque:
# - O Prisma está configurado para usar Data Proxy
# - Data Proxy requer URL no formato: prisma+postgres://accelerate.prisma-data.net/?api_key=...
# - Não usar postgresql:// normal
